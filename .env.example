# IPMax — 환경변수 예시
# 실제 값은 각 OS의 비밀 관리 도구(Keychain/DPAPI/Vault 등)에 저장하고
# 이 파일은 키 이름만 가이드 용으로 커밋한다. .env는 .gitignore에 의해 제외됨.

# ===== 서버 (Spring Boot) =====
DATABASE_URL=postgresql://localhost:5432/ipmax
DATABASE_USER=ipmax
DATABASE_PASSWORD=change-me

REDIS_URL=redis://localhost:6379/0

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601

JWT_SECRET=change-me-256bit
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# ===== 결제 PG =====
PG_PROVIDER=tosspayments
PG_CLIENT_KEY=
PG_SECRET_KEY=

# ===== Provider 라우터 =====
IPMAX_SERVER_BASE_URL=https://api.ipmax.example.com
IPMAX_PROVIDER_TOKEN=
IPMAX_HEARTBEAT_INTERVAL_SEC=10

# ===== 클라이언트 공통 =====
API_BASE_URL=https://api.ipmax.example.com/v1
